{
  "expo": {
    "name": "AI Fake News Detector",
    "slug": "ai-fake-news-detector-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.marouanelhachmi.aifakenewsdetector"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0d1117"
      },
      "package": "com.marouanelhachmi.aifakenewsdetector",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.INTERNET"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "aifakenewsdetector",
              "host": "auth",
              "pathPrefix": "/callback"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        { "cameraPermission": "Allow AI Fake News Detector to access your camera." }
      ],
      [
        "expo-image-picker",
        { "photosPermission": "Allow AI Fake News Detector to access your photos." }
      ]
    ],
    "scheme": "aifakenewsdetector",
    "extra": {
      "router": { "origin": false }
    }
  }
}
