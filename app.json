{
  "expo": {
    "name": "AI Fake News Detector",
    "slug": "ai-fake-news-detector-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.marouanelhachmi.aifakenewsdetector"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d1117"
      },
      "package": "com.marouanelhachmi.aifakenewsdetector",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.INTERNET"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow AI Fake News Detector to access your camera."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow AI Fake News Detector to access your photos."
        }
      ],
      "expo-web-browser"
    ],
    "scheme": "aifakenewsdetector",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "505af80c-d79f-424e-a2a0-6cdaf0827591"
      }
    },
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d1117"
    },
    "newArchEnabled": true
  }
}